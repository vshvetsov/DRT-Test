# Copy this file to .env.local and fill in real values before running the app.
# Any code that imports lib/env.ts will throw at load time if a required value is missing.

# Postgres connection string (Neon in production, local Postgres in dev).
# Example: postgres://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=

# Anthropic API key used by the /api/ask backend (server-only; never exposed to the client).
ANTHROPIC_API_KEY=

# 32+ character random string used to encrypt the session cookie.
# Generate with: `openssl rand -hex 32`
SESSION_SECRET=

# Optional — basic-auth gate applied to every route when BOTH are set.
# Leave unset in local dev; set in production before sharing the URL.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
